        "/api/truefoods-sanifu/get/uom-conversion": {
            "post": {
                "tags": [
                    "Items"
                ],
                "summary": "Get UOM Conversion",
                "description": "Get unit of measure conversion data. No parameters: Get all unit types. unitTypeId: Get all units for a specific unit type. unitTypeId + unitName: Get conversion rate for a specific unit. itemId: Get units from an item's unit type.",
                "operationId": "80d68219c05c4233e3a4c4a1551b7b6d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "company_id",
                                    "environment"
                                ],
                                "properties": {
                                    "company_id": {
                                        "description": "(mandatory) Company identifier",
                                        "type": "integer"
                                    },
                                    "environment": {
                                        "description": "(mandatory) Environment type",
                                        "type": "string",
                                        "enum": [
                                            "sandbox",
                                            "production"
                                        ]
                                    },
                                    "unitTypeId": {
                                        "description": "Unit type internal ID",
                                        "type": "string"
                                    },
                                    "unitName": {
                                        "description": "Specific unit name to get conversion rate for",
                                        "type": "string"
                                    },
                                    "itemId": {
                                        "description": "Item internal ID to get its unit type",
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful response"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        }
