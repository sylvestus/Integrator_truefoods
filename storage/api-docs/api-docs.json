                    {
                        "name": "company_id",
                        "in": "query",
                        "description": "Company identifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 6
                    },
                    {
                        "name": "environment",
                        "in": "query",
                        "description": "Environment type",
                        "required": true,
