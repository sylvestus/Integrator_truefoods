                        "example": "30/03/2026"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/api/truefoods-sanifu/create/sales-order": {
            "post": {
                "tags": [
                    "Sales Orders"
                ],
                "summary": "Create Sales Order",
                "description": "Create a new sales order",
                "operationId": "994b5c6c7cf96b1b1b23ed4a83a107de",
                "parameters": [
                    {
                        "name": "company_id",
                        "in": "query",
                        "description": "(mandatory) Company identifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 6
                    },
                    {
                        "name": "environment",
                        "in": "query",
                        "description": "(mandatory) Environment type",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "sandbox",
                                "production"
                            ]
                        },
                        "example": "sandbox"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "company_id",
                                    "environment",
                                    "customerId",
                                    "tranDate",
                                    "otherRefNum",
                                    "shipDate",
                                    "department",
                                    "location",
                                    "status",
                                    "items"
                                ],
                                "properties": {
                                    "company_id": {
                                        "description": "(mandatory) Company identifier",
                                        "type": "integer"
                                    },
                                    "environment": {
                                        "description": "(mandatory) Environment type",
                                        "type": "string",
                                        "enum": [
                                            "sandbox",
                                            "production"
                                        ]
                                    },
                                    "customerId": {
                                        "description": "(mandatory) Customer ID for the order",
                                        "type": "integer"
                                    },
                                    "status": {
                                        "description": "(mandatory) Order status",
                                        "type": "string",
                                        "enum": [
                                            "A",
                                            "B"
                                        ]
                                    },
                                    "memo": {
                                        "description": "Order memo/notes",
                                        "type": "string"
                                    },
                                    "tranDate": {
                                        "description": "(mandatory) Transaction date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "dueDate": {
                                        "description": "Due date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "shipDate": {
                                        "description": "(mandatory) Ship date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "otherRefNum": {
                                        "description": "(mandatory) External reference number (e.g., PO number)",
                                        "type": "string"
                                    },
                                    "terms": {
                                        "description": "Payment terms ID",
                                        "type": "integer"
                                    },
                                    "salesRep": {
                                        "description": "Sales representative ID",
                                        "type": "integer"
                                    },
                                    "department": {
                                        "description": "(mandatory) Department ID",
                                        "type": "integer"
                                    },
                                    "classId": {
                                        "description": "Class ID",
                                        "type": "integer"
                                    },
                                    "location": {
                                        "description": "(mandatory) Location ID",
                                        "type": "integer"
                                    },
                                    "salesType": {
                                        "description": "Sales type ID",
                                        "type": "integer"
                                    },
                                    "channel": {
                                        "description": "Sales channel ID",
                                        "type": "integer"
                                    },
                                    "region": {
                                        "description": "Region ID",
                                        "type": "integer"
                                    },
                                    "widgetLink": {
                                        "description": "Widget link URL",
                                        "type": "string"
                                    },
                                    "items": {
                                        "description": "(mandatory) Line items for the order",
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "itemId",
                                                "quantity",
                                                "taxCode",
                                                "location"
                                            ],
                                            "properties": {
                                                "itemId": {
                                                    "description": "(mandatory) Item ID",
                                                    "type": "integer"
                                                },
                                                "quantity": {
                                                    "description": "(mandatory) Quantity",
                                                    "type": "integer"
                                                },
                                                "rate": {
                                                    "description": "Unit price",
                                                    "type": "number"
                                                },
                                                "amount": {
                                                    "description": "Line total amount",
                                                    "type": "number"
                                                },
                                                "description": {
                                                    "description": "Line item description",
                                                    "type": "string"
                                                },
                                                "taxCode": {
                                                    "description": "(mandatory) Tax code ID",
                                                    "type": "integer"
                                                },
                                                "location": {
                                                    "description": "(mandatory) Item location ID",
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sales order created successfully"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
