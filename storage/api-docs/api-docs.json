{
    "openapi": "3.0.0",
    "info": {
        "title": "Truefoods Sanifu API",
        "description": "API for Truefoods Sanifu integration with NetSuite. This API provides endpoints for managing items, customers, customer purchases, and sales orders.",
        "contact": {
            "name": "API Support"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://netsuiteintegrator.dynamicsserv.com:4140",
            "description": "Production Server"
        }
    ],
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "User Login",
                "description": "Authenticate user and get access token",
                "operationId": "a8c99997ecfb28344616a3b8ffdb9590",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "description": "(mandatory) User email address",
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@example.com"
                                    },
                                    "password": {
                                        "description": "(mandatory) User password",
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/api/truefoods-sanifu/get/customers": {
            "post": {
                "tags": [
                    "Customers"
                ],
                "summary": "Get Customers",
                "description": "Retrieve a paginated list of customers with optional filters",
                "operationId": "f77e7776dc6e85b6fc5722d114396172",
                "parameters": [
                    {
                        "name": "company_id",
                        "in": "query",
                        "description": "(mandatory) Company identifier",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 6
                    },
                    {
                        "name": "environment",
                        "in": "query",
                        "description": "(mandatory) Environment type",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "sandbox",
                                "production"
                            ]
                        },
                        "example": "sandbox"
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number for pagination",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        },
                        "example": 1
                    },
                    {
                        "name": "customerId",
                        "in": "query",
                        "description": "Filter by specific customer ID",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "companyName",
                        "in": "query",
                        "description": "Filter by company name",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Filter by customer email",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "Filter by customer phone",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "isInactive",
                        "in": "query",
                        "description": "Filter by inactive status",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/api/truefoods-sanifu/get/customer-purchases": {
            "post": {
                "tags": [
                    "Customers"
                ],
                "summary": "Get Customer Purchases",
