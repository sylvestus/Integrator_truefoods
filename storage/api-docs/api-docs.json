                            ]
                        },
                        "example": "sandbox"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "company_id",
                                    "environment",
                                    "customerId",
                                    "tranDate",
                                    "otherRefNum",
                                    "shipDate",
                                    "department",
                                    "location",
                                    "status",
                                    "items"
                                ],
                                "properties": {
                                    "company_id": {
                                        "description": "Company identifier",
                                        "type": "integer"
                                    },
                                    "environment": {
                                        "description": "Environment type",
                                        "type": "string",
                                        "enum": [
                                            "sandbox",
                                            "production"
                                        ]
                                    },
                                    "customerId": {
                                        "description": "Customer ID for the order",
                                        "type": "integer"
                                    },
                                    "status": {
                                        "description": "Order status",
                                        "type": "string",
                                        "enum": [
                                            "A",
                                            "B"
                                        ]
                                    },
                                    "memo": {
                                        "description": "Order memo/notes",
                                        "type": "string"
                                    },
                                    "tranDate": {
                                        "description": "Transaction date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "dueDate": {
                                        "description": "Due date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "shipDate": {
                                        "description": "Ship date (YYYY-MM-DD)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "otherRefNum": {
                                        "description": "External reference number (e.g., PO number)",
                                        "type": "string"
                                    },
                                    "terms": {
                                        "description": "Payment terms ID",
                                        "type": "integer"
                                    },
                                    "salesRep": {
                                        "description": "Sales representative ID",
                                        "type": "integer"
                                    },
                                    "department": {
                                        "description": "Department ID",
                                        "type": "integer"
                                    },
                                    "classId": {
                                        "description": "Class ID",
                                        "type": "integer"
                                    },
                                    "location": {
                                        "description": "Location ID",
                                        "type": "integer"
                                    },
                                    "salesType": {
                                        "description": "Sales type ID",
                                        "type": "integer"
                                    },
                                    "channel": {
                                        "description": "Sales channel ID",
                                        "type": "integer"
                                    },
                                    "region": {
                                        "description": "Region ID",
                                        "type": "integer"
                                    },
                                    "widgetLink": {
                                        "description": "Widget link URL",
                                        "type": "string"
                                    },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "itemId",
                                                "quantity",
                                                "taxCode",
                                                "location"
                                            ],
                                            "properties": {
                                                "itemId": {
                                                    "description": "Item ID",
                                                    "type": "integer"
                                                },
                                                "quantity": {
                                                    "description": "Quantity",
                                                    "type": "integer"
                                                },
                                                "rate": {
                                                    "description": "Unit price",
                                                    "type": "number"
                                                },
                                                "amount": {
                                                    "description": "Line total amount",
                                                    "type": "number"
                                                },
                                                "description": {
                                                    "description": "Line item description",
                                                    "type": "string"
                                                },
                                                "taxCode": {
                                                    "description": "Tax code ID",
                                                    "type": "integer"
                                                },
                                                "location": {
                                                    "description": "Item location ID",
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sales order created successfully"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
