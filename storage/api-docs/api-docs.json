                                "invoice",
                                "salesorder",
                                "cashsale",
                                "creditmemo",
                                "returnauthorization",
                                "estimate"
                            ]
                        },
                        "example": "salesorder"
                    },
                    {
                        "name": "dateFrom",
                        "in": "query",
                        "description": "Start date filter (DD/MM/YYYY format)",
